{
  "env": {
    "browser": true,
    "es2022": true
  },
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "extends": ["eslint:recommended"],
  "globals": {
    "odoo": "readonly",
    "$": "readonly",
    "jQuery": "readonly",
    "luxon": "readonly",
    "Chart": "readonly",
    "QUnit": "readonly",
    "DOMPurify": "readonly",
    "FullCalendar": "readonly",
    "globalThis": "readonly",
    "owl": "readonly",
    "Alert": "readonly",
    "Collapse": "readonly",
    "Dropdown": "readonly",
    "Modal": "readonly",
    "Offcanvas": "readonly",
    "Popover": "readonly",
    "Tooltip": "readonly"
  },
  "rules": {
    "no-undef": "warn",
    "no-unused-vars": ["warn", {
      "vars": "all",
      "args": "none",
      "ignoreRestSiblings": true
    }],
    "no-const-assign": "error",
    "no-debugger": "error",
    "no-dupe-class-members": "error",
    "no-dupe-keys": "error",
    "no-dupe-args": "error",
    "no-dupe-else-if": "error",
    "no-duplicate-imports": "warn",
    "no-unsafe-negation": "error",
    "no-restricted-globals": ["error", "event"],
    "valid-typeof": "error",
    "no-eval": "error",
    "no-implied-eval": "error",
    "no-new-wrappers": "error",
    "no-throw-literal": "error",
    "no-self-compare": "error",
    "no-template-curly-in-string": "warn",
    "prefer-const": "off",
    "curly": "off",
    "arrow-body-style": "off",
    "eqeqeq": "off",
    "no-empty": "off",
    "no-empty-function": "off",
    "no-prototype-builtins": "off",
    "no-fallthrough": "off",
    "no-case-declarations": "off"
  },
  "ignorePatterns": [
    "**/static/lib/**",
    "**/static/src/lib/**"
  ]
}
